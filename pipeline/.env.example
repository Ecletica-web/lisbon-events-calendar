# ---- Scraping ----
APIFY_API_TOKEN=
# apify/instagram-scraper actor (default already set)
# APIFY_INSTAGRAM_ACTOR_ID=shu8hvrXbJbY3Eb9W
# per_account | batch
PIPELINE_RUN_MODE=batch
PIPELINE_MAX_POSTS_PER_ACCOUNT=20

# ---- Text LLM + Whisper ----
OPENAI_API_KEY=
PIPELINE_TEXT_MODEL=gpt-4o-mini
PIPELINE_VERIFY_MODEL=gpt-4o

# Online verification (optional Brave; otherwise OpenAI web_search)
# BRAVE_SEARCH_API_KEY=
# Set to 1 to auto-verify newly extracted Processed rows during extract
PIPELINE_VERIFY_ON_EXTRACT=0

# ---- Vision ----
# nvidia | openai (nvidia falls back to openai on failure)
PROCESSING_VISION_PROVIDER=nvidia
NVIDIA_NIM_API_KEY=
PROCESSING_VISION_NVIDIA_MODEL=nvidia/nemotron-nano-12b-v2-vl
PROCESSING_VISION_OPENAI_MODEL=gpt-4o

# ---- Document AI OCR (high ROI for flyer dates) ----
DOCUMENT_AI_ENABLED=0
DOCUMENT_AI_PROJECT_ID=
DOCUMENT_AI_LOCATION=eu
DOCUMENT_AI_PROCESSOR_ID=
# Inline JSON or path to service-account key file
DOCUMENT_AI_SERVICE_ACCOUNT_JSON=

# ---- Google Sheets (Watchlist + Processed Events only) ----
GOOGLE_SHEETS_ID=
# Inline JSON or path to service-account key file (needs edit access to the sheet)
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=

# ---- Supabase pipeline store (raw posts, AI tiers, review, verify, runs) ----
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- App bridge (persist-image) ----
EVENT_IMPORT_API_KEY=
APP_BASE_URL=http://localhost:3000

# ---- Media enrichment ----
INSTAGRAM_EMBED_CAROUSEL_FETCH=1
# Tier 4 video pass (requires ffmpeg on PATH for frames)
PIPELINE_VIDEO_FRAMES=0
PIPELINE_VIDEO_WHISPER=0

# ---- Venue resolution (same CSV the app uses) ----
NEXT_PUBLIC_VENUES_CSV_URL=

# ---- Thresholds ----
PIPELINE_BROAD_CONFIDENCE_THRESHOLD=0.7
PIPELINE_MERGE_CAPTION_DATETIME_THRESHOLD=0.8
PIPELINE_PUBLISH_CONFIDENCE_THRESHOLD=0.7
